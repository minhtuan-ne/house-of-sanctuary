generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid(7))
  name         String    @unique
  passwordHash String
  role         String    @default("USER")
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  writings     Writing[]
}

model Writing {
  id           String    @id @default(uuid(7))
  slug         String    @unique
  title        String
  excerpt      String?
  content      String
  coverImage   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  author       User      @relation(fields: [authorId], references: [id])
  authorId     String
}
